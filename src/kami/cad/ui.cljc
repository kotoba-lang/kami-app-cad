(ns kami.cad.ui (:require [html.core :as html] [css.core :as css]))
(def sheet {:rules {"*" {:box-sizing :border-box} "body" {:margin 0 :height "100vh" :display :grid :grid-template-rows "52px 1fr" :font-family "Inter,system-ui" :background "#090e18" :color "#edf2ff"} "header" {:display :flex :align-items :center :gap 18 :padding "0 16px" :background "#17223b"} "header .spacer" {:flex 1} "main" {:display :grid :grid-template-columns "230px 1fr 270px" :min-height 0} "aside" {:padding 16 :background "#101a2e" :border-right "1px solid #32466e"} "aside:last-child" {:border-left "1px solid #32466e" :border-right 0} ".viewport" {:position :relative} "#gpu-canvas" {:width "100%" :height "100%" :display :block} "#gpu-status" {:position :absolute :left "50%" :top "45%" :transform "translate(-50%,-50%)" :color "#ffb0b0"} "button,input,select" {:width "100%" :margin "5px 0" :padding 8 :background "#20345c" :color "#fff" :border "1px solid #5878b4" :border-radius 5} "button" {:cursor :pointer} ".primary" {:background "#79a2ff" :color "#071227" :font-weight 700} "h2" {:font-size 11 :letter-spacing ".12em" :text-transform :uppercase :color "#a8bce3"} "label" {:display :grid :gap 4 :margin "10px 0"} ".stats" {:position :absolute :right 14 :bottom 14 :background "#08101dcc" :padding 8}}})
(defn page [] (html/html5 [:html {:lang "en"} [:head [:meta {:charset "utf-8"}] [:meta {:name "viewport" :content "width=device-width,initial-scale=1"}] [:link {:rel "icon" :href "data:,"}] [:title "Kami CAD"] [:style (css/css sheet)]] [:body [:header [:strong "KAMI CAD · NURBS"] [:a {:href "https://kotoba-lang.github.io/kami-studio/"} "Studio"] [:span "WebGPU precision workspace"] [:span.spacer] [:button {:id "undo"} "Undo"] [:button {:id "redo"} "Redo"] [:button {:id "export"} "Export EDN"]] [:main [:aside [:h2 "Model"] [:button.primary "Loft Surface"] [:h2 "Tools"] [:button {:id "fit"} "Fit View"] [:button {:id "reset"} "Reset Sections"] [:h2 "Trim exact spans"] [:label "Start" [:input {:id "trim-start" :type "number" :min 0 :max 1 :step 0.05 :value 0.1}]] [:label "End" [:input {:id "trim-end" :type "number" :min 0 :max 1 :step 0.05 :value 0.9}]] [:button {:id "trim"} "Trim sections"] [:h2 "Precision"] [:select {:id "snap"} [:option {:value "0.1"} "Snap 0.1 mm"] [:option {:value "0.5"} "Snap 0.5 mm"] [:option {:value "1"} "Snap 1 mm"]]] [:section.viewport [:canvas {:id "gpu-canvas" :aria-label "NURBS WebGPU viewport"}] [:div {:id "gpu-status"} "Initializing WebGPU…"] [:div.stats {:id "stats"} "2 sections · 34 vertices"]] [:aside [:h2 "Control Point"] [:label "Section" [:select {:id "section-index"} [:option {:value 0} "Section 1"] [:option {:value 1} "Section 2"]]] [:label "Point" [:select {:id "point-index"} [:option {:value 0} "Point 1"] [:option {:value 1 :selected true} "Point 2"] [:option {:value 2} "Point 3"]]] [:label "X" [:input {:id "cp-x" :type "number" :step 0.1 :value 0}]] [:label "Y" [:input {:id "cp-y" :type "number" :step 0.1 :value 2}]] [:label "Z" [:input {:id "cp-z" :type "number" :step 0.1 :value 0}]] [:label "Weight" [:input {:id "weight" :type "number" :min 0.1 :step 0.1 :value 1}]] [:label "Tessellation" [:input {:id "segments" :type "range" :min 4 :max 64 :value 16}]] [:button.primary {:id "apply"} "Apply exact values"]]] [:span {:id "debug-state" :style {:display "none"}}] [:script {:src "./js/app.js"}]]]))
